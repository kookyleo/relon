    "@codemirror/lint": "^6.5.0",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.26.0",
    "vitepress": "^1.2.3"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2"
  }
