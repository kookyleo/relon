{
  "$comment": "Relon TextMate grammar. Kept in lock-step with the CodeMirror tokenizer at docs/.vitepress/theme/components/playground/relon-mode.ts. Token group -> scope name mapping (mirror the comment in relon-mode.ts): reference (&root, &sibling, ...) -> variable.language.relon; control (where, match, for, in, if, as, with) -> keyword.control.relon; type (Int, String, List, ...) -> support.type.relon; operator (==, !=, &&, =>, ->, ...) -> keyword.operator.relon.",
  "name": "relon",
  "scopeName": "source.relon",
  "fileTypes": [
    "relon"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#hash-keywords"
    },
    {
      "include": "#at-forms"
    },
    {
      "include": "#references"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#atoms"
    },
    {
      "include": "#control-keywords"
    },
    {
      "include": "#builtin-types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.relon",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.relon"
            }
          }
        },
        {
          "name": "comment.block.relon",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.relon"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.relon"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.interpolated.relon",
          "begin": "f\"",
          "end": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.relon"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.relon"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.relon",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.relon",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.relon"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.relon"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.relon",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "hash-keywords": {
      "patterns": [
        {
          "name": "keyword.control.directive.relon",
          "match": "#(?:schema|main|extend|derive|no_auto_derive|native|private|brand|import)\\b"
        },
        {
          "name": "entity.name.tag.directive.relon",
          "match": "#[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "at-forms": {
      "patterns": [
        {
          "name": "keyword.control.decorator.builtin.relon",
          "match": "@(?:schema|fn)\\b"
        },
        {
          "name": "entity.name.tag.decorator.relon",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "references": {
      "patterns": [
        {
          "name": "variable.language.relon",
          "match": "&(?:root|sibling|uncle|prev|next|index|this)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.relon",
          "match": "\\b\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "atoms": {
      "patterns": [
        {
          "name": "constant.language.boolean.relon",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.relon",
          "match": "\\b(?:where|match|for|in|if|as|with)\\b"
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "name": "support.type.relon",
          "match": "\\b(?:Int|Float|Number|String|Bool|Any|List|Dict|Tuple|Enum|Closure|Fn|Iter|Option|Result|Bytes|Date|Time|DateTime)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.spread.relon",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.arrow.relon",
          "match": "=>|->"
        },
        {
          "name": "keyword.operator.optional.relon",
          "match": "\\?\\.|\\?\\["
        },
        {
          "name": "keyword.operator.comparison.relon",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.relon",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.relon",
          "match": "\\+\\+|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.pipe.relon",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.ternary.relon",
          "match": "\\?"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.relon",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
