{
    "null"(value): type(value) == "Null",
    bool(value): type(value) == "Bool",
    int(value): type(value) == "Int",
    float(value): type(value) == "Float",
    number(value): type(value) == "Int" || type(value) == "Float",
    string(value): type(value) == "String",
    list(value): type(value) == "List",
    dict(value): type(value) == "Dict",
    empty(value): len(value) == 0
}
