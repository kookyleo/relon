// Standard library: math helpers. `#relaxed` so the polymorphic
// numeric parameters stay untyped at the source — the underlying
// host fns own the typing rules.
#relaxed
{
    abs(x): _math_abs(x),
    max(a, b): _math_max(a, b),
    min(a, b): _math_min(a, b),
    clamp(v, min, max): _math_clamp(v, min, max)
}
