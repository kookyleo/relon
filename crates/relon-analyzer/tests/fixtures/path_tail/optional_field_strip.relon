// v1.4 path-tail: an Optional schema reference still walks into its
// fields. `Option<Customer> customer` then `.name` strips the option and
// lands on String, matching the declared return.
// EXPECTED: no diagnostics.
#schema Customer { String name: * }
#schema Order { Option<Customer> customer: *, Int id: * }
#main(Order o) -> String
o.customer.name
