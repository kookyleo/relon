// Phase C.6: `#derive Addable` on a method whose signature matches
// the witness shape (`add(other: Self) -> Self`). The analyzer should
// shape-check it cleanly even though the evaluator-side lowering for
// `+` to-method dispatch isn't wired in yet.
#schema Vec2 {
    Float x: *,
    Float y: *
} with {
    #derive Addable
    add(other: Self) -> Self:
        { Vec2: { x: self.x + other.x, y: self.y + other.y } }
}

{ Vec2 v: { x: 1.0, y: 2.0 } }
